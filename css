/* style.css */
body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background-color: #fafafa;
    padding-bottom: 60px; /* Space for bottom nav */
    padding-top: 50px;    /* Space for top nav */
}

.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 15px;
    height: 50px;
    background: white;
    border-bottom: 1px solid #dbdbdb;
    position: fixed;
    top: 0; width: 100%; z-index: 10;
}

.logo { font-size: 1.5rem; font-weight: bold; }

.post {
    background: white;
    border-bottom: 1px solid #dbdbdb;
    margin-bottom: 10px;
}

.post-header {
    display: flex;
    align-items: center;
    padding: 10px;
    font-weight: 600;
}

.post-img {
    width: 100%;
    display: block;
}

.post-content { padding: 10px; }

.post-actions { font-size: 1.2rem; margin-bottom: 5px; }

.bottom-nav {
    display: flex;
    justify-content: space-around;
    align-items: center;
    position: fixed;
    bottom: 0; width: 100%;
    height: 50px;
    background: white;
    border-top: 1px solid #dbdbdb;
}
